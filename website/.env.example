# Storefront env — copy to `.env` and fill in. See ../ENV-SETUP.md for full details.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# OpenRouter — server-side only (never prefix with VITE_, never commit the real key)
OPENROUTER_API_KEY="sk-or-v1-your-key"
OPENROUTER_MODEL="openai/gpt-oss-120b:free"

# Menu source: "true" = bundled new menu (no DB migration needed); unset = live database
VITE_USE_STATIC_MENU="false"
